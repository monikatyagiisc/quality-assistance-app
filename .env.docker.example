# Copy to .env in the repo root before: docker compose up --build
#
#   cp .env.docker.example .env
#   # Edit .env and set credentials for your chosen backend

# Default backend (Gemini) — required when AGENT_BACKEND=gemini
GOOGLE_API_KEY=your-gemini-api-key

# Optional overrides
AGENT_BACKEND=gemini
AGENT_MODEL=gemini-2.0-flash
JWT_SECRET=change-me-docker-dev-secret
LOG_LEVEL=INFO

# OpenAI via LiteLLM (uncomment if using litellm)
# AGENT_BACKEND=litellm
# AGENT_MODEL=openai/gpt-4o-mini
# OPENAI_API_KEY=your-openai-api-key

# Amazon Bedrock (uncomment if using bedrock)
# AGENT_BACKEND=bedrock
# AGENT_MODEL=anthropic.claude-3-5-sonnet-20240620-v1:0
# AWS_ACCESS_KEY_ID=your-aws-access-key-id
# AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
# AWS_REGION_NAME=us-east-1
# AWS_SESSION_TOKEN=your-aws-session-token  # only for temporary credentials

# Ollama — local, free (uncomment if using ollama)
# AGENT_BACKEND=ollama
# AGENT_MODEL=llama3.2
# OLLAMA_API_BASE=http://host.docker.internal:11434
