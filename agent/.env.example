# Model backend: gemini | litellm | bedrock | ollama
AGENT_BACKEND=gemini
AGENT_MODEL=gemini-2.0-flash

# Gemini (when AGENT_BACKEND=gemini)
GOOGLE_API_KEY=your-gemini-api-key

# OpenAI via LiteLLM (when AGENT_BACKEND=litellm)
# AGENT_BACKEND=litellm
# AGENT_MODEL=openai/gpt-4o-mini
# OPENAI_API_KEY=your-openai-api-key

# Amazon Bedrock (when AGENT_BACKEND=bedrock)
# The 'bedrock/' prefix is added automatically if you omit it.
# AGENT_BACKEND=bedrock
# AGENT_MODEL=anthropic.claude-3-5-sonnet-20240620-v1:0
# AWS_ACCESS_KEY_ID=your-aws-access-key-id
# AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
# AWS_REGION_NAME=us-east-1
# Optional: only for temporary credentials (STS / assumed roles)
# AWS_SESSION_TOKEN=your-aws-session-token

# Ollama — local, free, no API key (when AGENT_BACKEND=ollama)
# The 'ollama/' prefix is added automatically if you omit it.
# AGENT_BACKEND=ollama
# AGENT_MODEL=llama3.2
# OLLAMA_API_BASE=http://localhost:11434
# Setup: https://ollama.com → install, then: ollama pull llama3.2

AGENT_HOST=0.0.0.0
AGENT_PORT=8001

# Logging: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
